# DOMAINE — ortam değişkenleri
# Bu dosyayı `.env.local` olarak kopyalayın. Hepsi opsiyoneldir; yoksa uygulama
# güvenli "demo" modlarına düşer ve hiçbir şey bozulmaz.

# --- Veritabanı (libSQL) ---
# Yerel geliştirme: dosya tabanlı (varsayılan).
DATABASE_URL=file:domaine.db
# Üretim (Vercel + Turso): bulut URL'i + token. Yerelde boş bırakın.
# DATABASE_URL=libsql://<db-adi>-<org>.turso.io
# DATABASE_AUTH_TOKEN=...

# --- AI Concierge & Intelligence (Claude) ---
# Anahtar varsa concierge ve zekâ raporları canlı Claude'a bağlanır;
# yoksa senaryolu/sentezlenen demo modu çalışır.
ANTHROPIC_API_KEY=sk-ant-...

# --- Auth ---
# Oturum JWT'lerini imzalamak için. Üretimde mutlaka rastgele uzun bir değer kullanın.
AUTH_SECRET=uzun-rastgele-bir-deger

# --- Stripe (üyelik ödemeleri) ---
# Anahtar varsa "Privé/Cercle Noir'e yükselt" gerçek Stripe Checkout açar.
# Yoksa yükseltme demo modunda anında uygulanır.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
